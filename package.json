{
  "name": "websocket-proxy",
  "version": "1.0.1",
  "description": "WebSocket proxy with UUID validation using ws ",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --exec node server.js",
    "dev:env": "nodemon -r dotenv/config server.js",
    "dev-screen": "./dev-screen.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "keywords": [
    "websocket",
    "proxy",
    "ws"
