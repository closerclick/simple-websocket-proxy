# Puerto del proxy WebSocket
PORT=4001

# --- Web Push (VAPID) ---
# OPCIONAL: si dejás estas dos vacías, el proxy autogenera un par la primera vez
# y lo persiste en SQLite (estable entre reinicios). Definilas solo si querés
# control explícito o compartir el mismo par entre varias instancias.
# Generá un par con: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Base SQLite donde se persiste lo durable (cola offline + push subscriptions)
PROXY_DB_FILE=./proxy-data.db
